{
  "name": "neo-vision",
  "version": "0.1.0",
  "description": "See the web the way Neo sees the Matrix. Deterministic spatial maps of web pages for AI agent navigation — pixel-precise coordinates, ARIA roles, actionability flags, and a built-in stealth layer that defeats anti-bot detection.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "bin": {
    "neo-vision": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "demo": "tsx src/demo.ts",
    "test:snapshot": "tsx src/test-snapshot.ts",
    "test:stealth": "tsx src/demo.ts --stealth-check",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "browser-automation",
    "web-scraping",
    "spatial-map",
    "dom",
    "stealth",
    "anti-bot",
    "anti-detection",
    "playwright",
    "claude",
    "openai",
    "langchain",
    "ai-navigation",
    "accessibility",
    "aria",
    "fingerprint-evasion",
    "human-like-automation",
    "neo-vision"
  ],
  "author": "Matthew Ong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matthewalexong/neo-vision"
  },
  "homepage": "https://github.com/matthewalexong/neo-vision#readme",
  "bugs": {
    "url": "https://github.com/matthewalexong/neo-vision/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "playwright": "^1.50.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
